class FlightTicket:
    airline = "Oceanic Airlines"
    airline_code = "OA"

    def __init__(self, flight_num, airport, gate, time, seat, passenger):
        self.flight_num = flight_num
        self.airport = airport
        self.gate = gate
        self.time = time
        self.seat = seat
        self.passenger = passenger

    def print_info(self):
        print("Airline:", FlightTicket.airline)
        print("Airline Code:", FlightTicket.airline_code)
        print("Flight Number:", self.flight_num)
        print("Airport:", self.airport)
        print("Gate:", self.gate)
        print("Time:", self.time)
        print("Seat:", self.seat)
        print("Passenger:", self.passenger)


flight_num = input("Enter flight number: ")
airport = input("Enter airport: ")
gate = input("Enter gate: ")
time = input("Enter time: ")
seat = input("Enter seat: ")
passenger = input("Enter passenger name: ")

ticket = FlightTicket(flight_num, airport, gate, time, seat, passenger)

ticket.print_info()